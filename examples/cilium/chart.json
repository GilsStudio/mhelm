{
  "apiVersion": "mhelm.io/v1alpha1",
  "mirror": {
    "upstream": {
      "type": "oci",
      "url": "oci://quay.io/cilium/charts/cilium",
      "version": "1.19.3"
    },
    "downstream": {
      "type": "oci",
      "url": "oci://ghcr.io/myorg/mirror"
    },
    "discoveryValues": [
      "helm/values.yml"
    ],
    "extraImages": [
      {
        "ref": "quay.io/cilium/cilium-cli:v0.18.0",
        "reason": "operator-managed; pulled at runtime by the cilium-cli CRD reconciler"
      },
      {
        "ref": "quay.io/cilium/operator-generic:v1.19.3",
        "valuesPath": "operator.image",
        "overridePath": "operator.image.override",
        "reason": "operator image is <repo>-generic with a per-cloud genericDigest; valuesPath maps it, overridePath bypasses the chart's suffix concatenation"
      }
    ],
    "verify": {
      "trustedIdentities": [
        {
          "subjectRegex": "https://github.com/cilium/.*",
          "issuer": "https://token.actions.githubusercontent.com"
        }
      ],
      "allowUnsigned": [
        "cilium/hubble-ui"
      ]
    },
    "vulnPolicy": {
      "failOn": "critical",
      "allowlist": [
        {
          "cve": "CVE-2024-1234",
          "expires": "2026-12-31",
          "reason": "tracked upstream in cilium#54321; no patch available yet"
        }
      ]
    }
  },
  "wrap": {
    "name":    "cilium-wrapped",
    "version": "1.19.3-myorg.1",
    "valuesFiles": [
      "helm/values.yml"
    ],
    "extraManifests": [
      "k8s/l2-announcement-policy.yml"
    ]
  },
  "release": {
    "name":      "cilium",
    "namespace": "kube-system",
    "valuesFiles": [
      "helm/install-overrides.yml"
    ]
  }
}
